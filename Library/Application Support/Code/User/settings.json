{
  "files.autoSave": "onFocusChange",
  "workbench.colorTheme": "Default Light Modern",
  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.enable": { "*": false }, // mostly don't want the completions but don't know how to turn just that off (see above)
  "gitlens.ai.enabled": false,
  "vim.leader": "<space>",
  "vim.foldfix": true,
  "window.autoDetectColorScheme": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    // basic editing
    {
      "before": ["v", "v"],
      "after": ["V"],
    },
    {
      "before": ["<leader>", ";", ";"],
      "commands": ["editor.action.commentLine"],
    },

    {
      "before": ["<leader>", "'"],
      "commands": ["terminal.focus"],
    },
    {
      "before": ["<leader>", "f", "s"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": ["<leader>", "b", "b"],
      "commands": ["workbench.action.quickOpen"],
    },
    {
      "before": ["<leader>", "<tab>"],
      "commands": ["workbench.action.nextEditor"],
    },
    {
      "before": ["<leader>", "<shift+tab>"],
      "commands": ["workbench.action.previousEditor"],
    },
    {
      "before": ["<leader>", "v"],
      "commands": ["editor.action.smartSelect.expand"],
    },
    {
      "before": ["<leader>", "h"],
      "commands": ["editor.action.showHover"],
    },
    {
      "before": ["<leader>", "f", "y", "y"],
      "commands": ["copyFilePath"],
    },
    // lsp
    {
      "before": [",", "r", "r"],
      "commands": ["editor.action.rename"],
    },
    {
      "before": [",", "g", "r"],
      "commands": ["editor.action.goToReferences"],
    },

    // window management
    {
      "before": ["<leader>", "w", "/"],
      "commands": ["workbench.action.splitEditor"],
    },
    {
      "before": ["<leader>", "w", "-"],
      "commands": ["workbench.action.splitEditorDown"],
    },
    {
      "before": ["<leader>", "w", "l"],
      "commands": ["workbench.action.focusRightGroup"],
    },
    {
      "before": ["<leader>", "w", "h"],
      "commands": ["workbench.action.focusLeftGroup"],
    },
    {
      "before": ["<leader>", "w", "j"],
      "commands": ["workbench.action.focusBelowGroup"],
    },
    {
      "before": ["<leader>", "w", "k"],
      "commands": ["workbench.action.focusAboveGroup"],
    },
    {
      "before": ["<leader>", "b", "d"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", ";", ";"],
      "commands": ["editor.action.commentLine"],
    },
    {
      "before": ["<leader>", "v"],
      "commands": ["editor.action.smartSelect.expand"],
    },
  ],
}
