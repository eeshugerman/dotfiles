{
  "workbench.colorTheme": "Default Light Modern",
  "github.copilot.nextEditSuggestions.enabled": true,
  "gitlens.ai.enabled": false,
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["v", "v"],
      "after": ["V"]
    },
    {
      "before": ["<leader>", "'"],
      "commands": ["terminal.focus"]
    }
  ]
}
